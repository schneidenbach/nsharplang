{
  "$schema": "http://json.schemastore.org/template",
  "author": "N# Team",
  "classifications": ["Test", "xUnit", "N#"],
  "identity": "NSharp.Test",
  "name": "N# Test Project",
  "shortName": "nsharp-test",
  "tags": {
    "language": "N#",
    "type": "project"
  },
  "sourceName": "TestProject",
  "preferNameDirectory": true,
  "symbols": {
    "Framework": {
      "type": "parameter",
      "description": "The target framework for the project",
      "datatype": "choice",
      "choices": [
        {
          "choice": "net10.0",
          "description": ".NET 10.0"
        },
        {
          "choice": "net9.0",
          "description": ".NET 9.0"
        },
        {
          "choice": "net8.0",
          "description": ".NET 8.0"
        }
      ],
      "defaultValue": "net10.0",
      "replaces": "net10.0"
    }
  }
}
