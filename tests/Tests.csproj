<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <RootNamespace>NSharpLang.Tests</RootNamespace>
    <!-- Disable test parallelization to avoid resource contention -->
    <ParallelizeTestCollections>false</ParallelizeTestCollections>
    <ParallelizeAssembly>false</ParallelizeAssembly>
    <!-- Exclude sub-projects that have their own .csproj, and fixture build artifacts -->
    <DefaultItemExcludes>$(DefaultItemExcludes);**/obj/**;**/bin/**;NSharpLang.IntegrationTests/**;NSharpLang.CSharpInteropTests/**;fixtures/**/obj/**;fixtures/**/bin/**</DefaultItemExcludes>
  </PropertyGroup>

  <!-- Exclude sub-projects — they have their own .csproj files -->
  <ItemGroup>
    <Compile Remove="NSharpLang.IntegrationTests/**" />
    <Compile Remove="NSharpLang.CSharpInteropTests/**" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.EntityFrameworkCore" Version="10.0.0" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.8.0" />
    <PackageReference Include="xunit" Version="2.6.2" />
    <PackageReference Include="NUnit" Version="3.14.0" />
    <PackageReference Include="xunit.runner.visualstudio" Version="2.5.4">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <PackageReference Include="coverlet.msbuild" Version="6.0.2">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers</IncludeAssets>
    </PackageReference>
    <PackageReference Include="Testcontainers" Version="4.3.0" />
    <!-- ASP.NET Core assemblies for analyzer tests -->
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\src\NSharpLang.Cli\Cli.csproj" />
    <ProjectReference Include="..\src\NSharpLang.Compiler\Compiler.csproj" />
    <ProjectReference Include="..\src\NSharpLang.LanguageServer\LanguageServer.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="OmniSharp.Extensions.LanguageServer" Version="0.19.9" />
    <PackageReference Include="Microsoft.Extensions.Logging" Version="9.0.0" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="9.0.0" />
  </ItemGroup>

  <ItemGroup>
    <None Update="xunit.runner.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <!-- Exclude sub-projects - they have their own .csproj files -->
  <ItemGroup>
    <Compile Remove="NSharpLang.IntegrationTests\**" />
    <Compile Remove="NSharpLang.CSharpInteropTests\**" />
  </ItemGroup>

</Project>
