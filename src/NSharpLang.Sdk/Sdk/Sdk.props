<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <PropertyGroup>
    <!-- Auto-detect project.yml in project directory -->
    <NSharpProjectFile Condition="'$(NSharpProjectFile)' == '' And Exists('$(MSBuildProjectDirectory)/project.yml')">$(MSBuildProjectDirectory)/project.yml</NSharpProjectFile>

    <!-- Prevent stale generated sources under ./nsharp from being compiled by default globs -->
    <DefaultItemExcludes>$(DefaultItemExcludes);$(MSBuildProjectDirectory)/nsharp/**</DefaultItemExcludes>

    <!-- Enable by default -->
    <EnableNSharpCompilation Condition="'$(EnableNSharpCompilation)' == ''">true</EnableNSharpCompilation>
  </PropertyGroup>

  <!-- Import build configuration generated by 'nlc restore' from project.yml.
       This file is the single canonical projection from YAML to MSBuild XML,
       generated by the real YAML parser (YamlDotNet), not regex. -->
  <Import Project="$(MSBuildProjectDirectory)/obj/project.g.props"
          Condition="Exists('$(MSBuildProjectDirectory)/obj/project.g.props')" />

  <!-- Minimum defaults so MSBuild evaluation doesn't crash when project.g.props
       is missing. The validation target in Sdk.targets will emit a clear error
       at build time if project.yml exists but project.g.props does not. -->
  <PropertyGroup>
    <TargetFramework Condition="'$(TargetFramework)' == ''">net9.0</TargetFramework>
    <OutputType Condition="'$(OutputType)' == ''">Exe</OutputType>
    <_NSharpBaseSdk Condition="'$(_NSharpBaseSdk)' == ''">Microsoft.NET.Sdk</_NSharpBaseSdk>
  </PropertyGroup>

  <!-- N# exe projects provide their own entry points via transpiled .nl files,
       so disable auto-generated Program.cs to avoid duplicate Main conflicts.
       Library projects with tests need the test SDK to generate the entry point,
       so GenerateProgramFile stays enabled (default) for Library.
       This must be set at evaluation time, before Microsoft.NET.Test.Sdk's
       InitialTargets runs the GenerateProgramFile target. -->
  <PropertyGroup Condition="'$(OutputType)' == 'Exe'">
    <GenerateProgramFile>false</GenerateProgramFile>
  </PropertyGroup>

  <!-- Import base SDK props (dynamic based on project.yml sdk field) -->
  <Import Project="Sdk.props" Sdk="$(_NSharpBaseSdk)" />

</Project>
