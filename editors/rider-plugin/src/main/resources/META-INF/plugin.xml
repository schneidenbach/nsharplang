<idea-plugin>
    <id>com.nsharp.rider</id>
    <name>N# Language Support</name>
    <vendor email="support@nsharp.dev" url="https://nsharp.dev">N# Team</vendor>

    <description><![CDATA[
        <h1>N# Language Support for Rider</h1>
        <p>
            Adds support for the N# programming language - a pragmatic language targeting .NET/CLI that combines
            Go-inspired syntax with discriminated unions and structural typing.
        </p>
        <br/>
        <p><b>Features:</b></p>
        <ul>
            <li>Syntax highlighting for .nl files</li>
            <li>File templates for new N# files</li>
            <li>Color settings page for customizing highlight colors</li>
        </ul>
        <br/>
        <p>Learn more at <a href="https://nsharp.dev">nsharp.dev</a></p>
    ]]></description>

    <change-notes><![CDATA[
        <h2>Version 0.1.0</h2>
        <ul>
            <li>Initial release</li>
            <li>Syntax highlighting and color settings</li>
        </ul>
    ]]></change-notes>

    <!-- Require Rider -->
    <depends>com.intellij.modules.rider</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- File Type -->
        <fileType
            name="N#"
            implementationClass="com.nsharp.NSharpFileType"
            fieldName="INSTANCE"
            language="NSharp"
            extensions="nl"/>

        <!-- Syntax Highlighter -->
        <lang.syntaxHighlighterFactory
            language="NSharp"
            implementationClass="com.nsharp.NSharpSyntaxHighlighterFactory"/>

        <!-- Color Settings Page -->
        <colorSettingsPage
            implementation="com.nsharp.NSharpColorSettingsPage"/>

    </extensions>
</idea-plugin>
