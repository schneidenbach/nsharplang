<idea-plugin>
    <id>com.nsharp.rider</id>
    <name>N# Language Support</name>
    <vendor email="support@nsharp.dev" url="https://nsharp.dev">N# Team</vendor>

    <description><![CDATA[
        <h1>N# Language Support for Rider</h1>
        <p>
            Adds support for the N# programming language - a pragmatic language targeting .NET/CLI that combines
            Go-inspired syntax with discriminated unions and structural typing.
        </p>
        <br/>
        <p><b>Features:</b></p>
        <ul>
            <li>Syntax highlighting for .nl files</li>
            <li>Recognition of project.yml project files</li>
            <li>Build integration with dotnet build</li>
            <li>Run configurations for N# projects</li>
            <li>File templates for new N# files</li>
        </ul>
        <br/>
        <p>Learn more at <a href="https://nsharp.dev">nsharp.dev</a></p>
    ]]></description>

    <change-notes><![CDATA[
        <h2>Version 0.1.0</h2>
        <ul>
            <li>Initial release</li>
            <li>Basic syntax highlighting for .nl files</li>
            <li>project.yml file recognition</li>
            <li>Build and run configurations</li>
        </ul>
    ]]></change-notes>

    <!-- Require Rider -->
    <depends>com.intellij.modules.rider</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- File Type -->
        <fileType
            name="N#"
            implementationClass="com.nsharp.NSharpFileType"
            fieldName="INSTANCE"
            language="NSharp"
            extensions="nl"/>

        <!-- Language -->
        <lang.parserDefinition
            language="NSharp"
            implementationClass="com.nsharp.NSharpParserDefinition"/>

        <!-- Syntax Highlighter -->
        <lang.syntaxHighlighterFactory
            language="NSharp"
            implementationClass="com.nsharp.NSharpSyntaxHighlighterFactory"/>

        <!-- Color Settings Page -->
        <colorSettingsPage
            implementation="com.nsharp.NSharpColorSettingsPage"/>

        <!-- Run Configuration -->
        <configurationType
            implementation="com.nsharp.run.NSharpConfigurationType"/>

        <runConfigurationProducer
            implementation="com.nsharp.run.NSharpRunConfigurationProducer"/>

        <!-- Project View -->
        <projectViewNodeDecorator
            implementation="com.nsharp.project.NSharpProjectViewNodeDecorator"/>

        <!-- Icons -->
        <iconProvider
            implementation="com.nsharp.icons.NSharpIconProvider"/>
    </extensions>

    <actions>
        <!-- Build Actions -->
        <action id="NSharp.Build"
                class="com.nsharp.actions.NSharpBuildAction"
                text="Build N# Project"
                description="Build the current N# project using dotnet build"
                icon="AllIcons.Actions.Compile">
            <add-to-group group-id="BuildMenu" anchor="first"/>
        </action>

        <action id="NSharp.Rebuild"
                class="com.nsharp.actions.NSharpRebuildAction"
                text="Rebuild N# Project"
                description="Clean and rebuild the current N# project"
                icon="AllIcons.Actions.ForceRefresh">
            <add-to-group group-id="BuildMenu" anchor="after" relative-to-action="NSharp.Build"/>
        </action>

        <!-- New File Action -->
        <action id="NSharp.NewFile"
                class="com.nsharp.actions.NewNSharpFileAction"
                text="N# File"
                description="Create new N# file"
                icon="com.nsharp.icons.NSharpIcons.FILE">
            <add-to-group group-id="NewGroup" anchor="before" relative-to-action="NewFile"/>
        </action>
    </actions>
</idea-plugin>
