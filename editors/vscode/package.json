{
  "name": "nsharp",
  "displayName": "N# Language Support",
  "description": "Full language support for N# — a Go-inspired language for .NET. IntelliSense, diagnostics, formatting, debugging, and more.",
  "version": "0.6.0",
  "publisher": "nsharp",
  "repository": {
    "type": "git",
    "url": "https://github.com/anthropics/NewCLILang"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Formatters"
  ],
  "icon": "icon.png",
  "keywords": [
    "nsharp",
    "n#",
    "dotnet",
    "clr",
    "go"
  ],
  "main": "./out/src/extension.js",
  "activationEvents": [
    "onLanguage:nsharp"
  ],
  "contributes": {
    "commands": [
      {
        "command": "nsharp.generateDebugConfig",
        "title": "N#: Generate Debug Configuration"
      }
    ],
    "languages": [
      {
        "id": "nsharp",
        "aliases": [
          "N#",
          "nsharp"
        ],
        "extensions": [
          ".nl",
          ".tests.nl"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/nsharp-file-light.svg",
          "dark": "./icons/nsharp-file-dark.svg"
        }
      }
    ],
    "snippets": [
      {
        "language": "nsharp",
        "path": "./snippets/nsharp.json"
      }
    ],
    "grammars": [
      {
        "language": "nsharp",
        "scopeName": "source.nsharp",
        "path": "./syntaxes/nsharp.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "N#",
      "properties": {
        "nsharp.languageServer.path": {
          "type": "string",
          "default": "",
          "description": "Path to the N# language server executable. Leave empty to use bundled server."
        },
        "nsharp.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Traces the communication between VS Code and the language server."
        },
        "nsharp.format.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable N# code formatting."
        }
      }
    },
    "configurationDefaults": {
      "[nsharp]": {
        "editor.formatOnSave": true
      }
    },
    "breakpoints": [
      {
        "language": "nsharp"
      }
    ],
    "taskDefinitions": [
      {
        "type": "nsharp"
      }
    ]
  },
  "scripts": {
    "build-server": "dotnet publish ../../src/NSharpLang.LanguageServer/LanguageServer.csproj -c Release -o ./server --self-contained false",
    "vscode:prepublish": "npm run build-server && npm run compile",
    "compile": "node ./node_modules/typescript/lib/tsc.js -p ./",
    "watch": "node ./node_modules/typescript/lib/tsc.js -watch -p ./",
    "package": "npm run build-server && vsce package",
    "pretest": "npm run build-server && npm run compile",
    "test": "node ./out/test/runTest.js",
    "test:headless": "node ./out/test/runTest.js",
    "test:smoke": "TEST_SUITE=extension,diagnostics,hover,completion node ./out/test/runTest.js"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@vscode/test-electron": "^2.5.2",
    "@types/mocha": "^10.0.7",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.75.0",
    "@vscode/vsce": "^2.32.0",
    "glob": "^10.4.0",
    "mocha": "^10.7.0",
    "typescript": "^5.9.3"
  }
}
