{
  "name": "nsharp",
  "displayName": "N# Language Support",
  "description": "Full language support for N# — a Go-inspired language for .NET. IntelliSense, diagnostics, formatting, tasks, and more.",
  "version": "0.6.0",
  "publisher": "nsharp",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/anthropics/NewCLILang"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Formatters",
    "Debuggers"
  ],
  "icon": "icon.png",
  "keywords": [
    "nsharp",
    "n#",
    "dotnet",
    "clr",
    "go"
  ],
  "main": "./out/src/extension.js",
  "activationEvents": [
    "onLanguage:nsharp",
    "onTaskType:nsharp",
    "onCommand:nsharp.runProject",
    "onCommand:nsharp.debugProject",
    "onDebugInitialConfigurations:nsharp",
    "onDebugResolve:nsharp",
    "workspaceContains:project.yml"
  ],
  "contributes": {
    "commands": [
      {
        "command": "nsharp.runProject",
        "title": "N#: Run Project",
        "category": "N#"
      },
      {
        "command": "nsharp.debugProject",
        "title": "N#: Debug Project",
        "category": "N#"
      }
    ],
    "languages": [
      {
        "id": "nsharp",
        "aliases": [
          "N#",
          "nsharp"
        ],
        "extensions": [
          ".nl",
          ".tests.nl"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/nsharp-file-light.svg",
          "dark": "./icons/nsharp-file-dark.svg"
        }
      }
    ],
    "snippets": [
      {
        "language": "nsharp",
        "path": "./snippets/nsharp.json"
      }
    ],
    "grammars": [
      {
        "language": "nsharp",
        "scopeName": "source.nsharp",
        "path": "./syntaxes/nsharp.tmLanguage.json"
      }
    ],
    "semanticTokenModifiers": [
      {
        "id": "catchResult",
        "description": "N# tuple-deconstruction binding that receives a captured exception."
      }
    ],
    "semanticTokenScopes": [
      {
        "language": "nsharp",
        "scopes": {
          "variable.catchResult": [
            "variable.other.catch-result.nsharp"
          ]
        }
      }
    ],
    "breakpoints": [
      {
        "language": "nsharp"
      }
    ],
    "debuggers": [
      {
        "type": "nsharp",
        "label": "N# (.NET)",
        "languages": [
          "nsharp"
        ],
        "configurationAttributes": {
          "launch": {
            "required": [],
            "properties": {
              "project": {
                "type": "string",
                "default": "${workspaceFolder}",
                "description": "N# project directory containing project.yml."
              },
              "args": {
                "type": "array",
                "default": [],
                "description": "Command-line arguments passed to the debugged program."
              },
              "cwd": {
                "type": "string",
                "default": "${workspaceFolder}",
                "description": "Working directory for the debugged program."
              },
              "console": {
                "type": "string",
                "enum": [
                  "internalConsole",
                  "integratedTerminal",
                  "externalTerminal"
                ],
                "default": "integratedTerminal",
                "description": "Where program output is displayed."
              },
              "stopAtEntry": {
                "type": "boolean",
                "default": false,
                "description": "Stop at the program entry point."
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "nsharp",
            "request": "launch",
            "name": "Launch N# Project",
            "project": "${workspaceFolder}",
            "args": [],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "stopAtEntry": false
          }
        ],
        "configurationSnippets": [
          {
            "label": "N#: Launch Project",
            "description": "Debug the current N# executable project.",
            "body": {
              "type": "nsharp",
              "request": "launch",
              "name": "Launch N# Project",
              "project": "${workspaceFolder}",
              "args": [],
              "cwd": "${workspaceFolder}",
              "console": "integratedTerminal",
              "stopAtEntry": false
            }
          }
        ]
      }
    ],
    "configuration": {
      "title": "N#",
      "properties": {
        "nsharp.languageServer.path": {
          "type": "string",
          "default": "",
          "description": "Path to the N# language server executable. Leave empty to use bundled server."
        },
        "nsharp.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Traces the communication between VS Code and the language server."
        },
        "nsharp.format.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable N# code formatting."
        },
        "nsharp.cli.path": {
          "type": "string",
          "default": "",
          "description": "Path to the nlc executable. Leave empty to use nlc from PATH."
        }
      }
    },
    "configurationDefaults": {
      "editor.semanticTokenColorCustomizations": {
        "rules": {
          "variable.catchResult:nsharp": {
            "foreground": "#D19A66"
          }
        }
      },
      "[nsharp]": {
        "editor.formatOnSave": true,
        "editor.semanticHighlighting.enabled": true
      }
    },
    "taskDefinitions": [
      {
        "type": "nsharp",
        "properties": {
          "task": {
            "type": "string",
            "description": "The N# task name."
          }
        }
      }
    ]
  },
  "scripts": {
    "build-server": "dotnet publish ../../src/NSharpLang.LanguageServer/LanguageServer.csproj -c Release -o ./server --self-contained false",
    "vscode:prepublish": "npm run build-server && npm run compile",
    "compile": "node ./node_modules/typescript/lib/tsc.js -p ./",
    "watch": "node ./node_modules/typescript/lib/tsc.js -watch -p ./",
    "package": "npm run build-server && vsce package",
    "pretest": "npm run build-server && npm run compile",
    "test": "node ./out/test/runTest.js",
    "test:headless": "node ./out/src/test/runTest.js",
    "test:smoke": "TEST_SUITE=extension,diagnostics,hover,completion node ./out/test/runTest.js"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@vscode/test-electron": "^2.5.2",
    "@types/mocha": "^10.0.7",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.75.0",
    "@vscode/vsce": "^2.32.0",
    "glob": "^10.4.0",
    "mocha": "^10.7.0",
    "typescript": "^5.9.3"
  }
}
