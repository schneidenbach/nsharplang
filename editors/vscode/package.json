{
  "name": "nsharp",
  "displayName": "N# Language Support",
  "description": "Language support for N# (.nl files) with comprehensive IntelliSense, type resolution, signature help, and diagnostics",
  "version": "0.6.0",
  "publisher": "nsharp",
  "repository": {
    "type": "git",
    "url": "https://github.com/anthropics/NewCLILang"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Formatters"
  ],
  "keywords": [
    "nsharp",
    "n#",
    ".NET",
    "CLI",
    "transpiler"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:nsharp"
  ],
  "contributes": {
    "commands": [
      {
        "command": "nsharp.generateDebugConfig",
        "title": "N#: Generate Debug Configuration"
      }
    ],
    "languages": [
      {
        "id": "nsharp",
        "aliases": ["N#", "nsharp"],
        "extensions": [".nl", ".tests.nl"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "nsharp",
        "scopeName": "source.nsharp",
        "path": "./syntaxes/nsharp.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "N#",
      "properties": {
        "nsharp.languageServer.path": {
          "type": "string",
          "default": "",
          "description": "Path to the N# language server executable. Leave empty to use bundled server."
        },
        "nsharp.trace.server": {
          "type": "string",
          "enum": ["off", "messages", "verbose"],
          "default": "off",
          "description": "Traces the communication between VS Code and the language server."
        },
        "nsharp.format.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable N# code formatting."
        }
      }
    },
    "configurationDefaults": {
      "[nsharp]": {
        "editor.formatOnSave": true
      }
    }
  },
  "scripts": {
    "build-server": "dotnet publish ../../src/NSharpLang.LanguageServer/LanguageServer.csproj -c Release -o ./server --self-contained false",
    "vscode:prepublish": "npm run build-server && npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npm run build-server && vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.75.0",
    "typescript": "^5.0.0",
    "@vscode/vsce": "^2.22.0"
  }
}
