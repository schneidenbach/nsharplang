{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "N#",
  "scopeName": "source.nsharp",
  "patterns": [
    { "include": "#preprocessor" },
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#attributes" },
    { "include": "#declarations" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#functions" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "preprocessor": {
      "patterns": [
        {
          "name": "meta.preprocessor.nsharp",
          "match": "^\\s*#(if|else|elif|endif|define|undef|warning|error|line|region|endregion|pragma)\\b.*$"
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.nsharp",
          "match": "//.*$"
        },
        {
          "name": "comment.block.nsharp",
          "begin": "/\\*",
          "end": "\\*/"
        },
        {
          "name": "comment.block.documentation.nsharp",
          "begin": "///",
          "end": "$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.interpolated.nsharp",
          "begin": "(\\$)\"",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.string.interpolated.nsharp" }
          },
          "end": "\"",
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.nsharp" }
          },
          "patterns": [
            {
              "name": "constant.character.escape.nsharp",
              "match": "\\\\."
            },
            {
              "name": "meta.interpolation.nsharp",
              "begin": "\\{",
              "beginCaptures": {
                "0": { "name": "punctuation.definition.interpolation.begin.nsharp" }
              },
              "end": "\\}",
              "endCaptures": {
                "0": { "name": "punctuation.definition.interpolation.end.nsharp" }
              },
              "patterns": [{ "include": "$self" }]
            }
          ]
        },
        {
          "name": "string.quoted.triple.nsharp",
          "begin": "(\\$?)\"\"\"",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.string.interpolated.nsharp" }
          },
          "end": "\"\"\"",
          "patterns": [
            {
              "name": "meta.interpolation.nsharp",
              "begin": "\\{",
              "beginCaptures": {
                "0": { "name": "punctuation.definition.interpolation.begin.nsharp" }
              },
              "end": "\\}",
              "endCaptures": {
                "0": { "name": "punctuation.definition.interpolation.end.nsharp" }
              },
              "patterns": [{ "include": "$self" }]
            }
          ]
        },
        {
          "name": "string.quoted.double.nsharp",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.nsharp",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.nsharp",
          "match": "\\b(if|else|for|foreach|while|return|break|continue|match|switch|case|when|yield|await|async|throw|try|catch|finally|using|lock)\\b"
        },
        {
          "name": "keyword.other.nsharp",
          "match": "\\b(func|class|struct|record|interface|enum|union|namespace|package|import|using|new|this|base|static|virtual|override|abstract|sealed|partial|readonly|const|file|duck|constructor)\\b"
        },
        {
          "name": "keyword.other.special.nsharp",
          "match": "\\b(print|test|assert)\\b"
        },
        {
          "name": "storage.modifier.nsharp",
          "match": "\\b(public|private|internal|protected|required|init)\\b"
        },
        {
          "name": "storage.type.nsharp",
          "match": "\\b(let|var|const|type|out|ref|params)\\b"
        },
        {
          "name": "constant.language.nsharp",
          "match": "\\b(true|false|null)\\b"
        },
        {
          "name": "keyword.operator.nsharp",
          "match": "\\b(is|as|typeof|nameof|checked|unchecked|and|or|not|with|immutable|implicit|explicit|operator)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.nsharp",
          "match": "\\b(int|long|float|double|bool|string|void|object|byte|short|char|decimal|uint|ulong|ushort|sbyte)\\b"
        },
        {
          "name": "meta.type.generic.nsharp",
          "begin": "\\b([A-Z][a-zA-Z0-9]*)\\s*(<)",
          "beginCaptures": {
            "1": { "name": "entity.name.type.nsharp" },
            "2": { "name": "punctuation.definition.typeparameters.begin.nsharp" }
          },
          "end": ">",
          "endCaptures": {
            "0": { "name": "punctuation.definition.typeparameters.end.nsharp" }
          },
          "patterns": [
            { "include": "#types" },
            {
              "name": "punctuation.separator.nsharp",
              "match": ","
            }
          ]
        },
        {
          "name": "entity.name.type.nsharp",
          "match": "\\b[A-Z][a-zA-Z0-9]*\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.nsharp",
          "match": "\\b0[xX][0-9a-fA-F]+[lLuU]*\\b"
        },
        {
          "name": "constant.numeric.binary.nsharp",
          "match": "\\b0[bB][01]+[lLuU]*\\b"
        },
        {
          "name": "constant.numeric.float.nsharp",
          "match": "\\b\\d+\\.\\d+([eE][+-]?\\d+)?[fFdDmM]?\\b"
        },
        {
          "name": "constant.numeric.integer.nsharp",
          "match": "\\b\\d+([eE][+-]?\\d+)?[lLuUfFdDmM]?\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.nsharp",
          "match": ":=|="
        },
        {
          "name": "keyword.operator.comparison.nsharp",
          "match": "==|!=|<|>|<=|>="
        },
        {
          "name": "keyword.operator.arithmetic.nsharp",
          "match": "\\+|-|\\*|/|%"
        },
        {
          "name": "keyword.operator.logical.nsharp",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.nullable.nsharp",
          "match": "\\?\\?|\\?\\.?|\\?\\[|\\!\\."
        },
        {
          "name": "keyword.operator.lambda.nsharp",
          "match": "=>"
        },
        {
          "name": "keyword.operator.spread.nsharp",
          "match": "\\.\\.\\.?"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.nsharp",
          "match": "\\b([a-z][a-zA-Z0-9]*)\\s*(?=\\()"
        },
        {
          "name": "entity.name.function.nsharp",
          "match": "\\b([A-Z][a-zA-Z0-9]*)\\s*(?=\\()"
        }
      ]
    },
    "attributes": {
      "patterns": [
        {
          "name": "meta.attribute.nsharp",
          "begin": "\\[",
          "end": "\\]",
          "patterns": [
            {
              "name": "entity.name.type.attribute.nsharp",
              "match": "[A-Z][a-zA-Z0-9]*"
            }
          ]
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "name": "meta.declaration.namespace.nsharp",
          "match": "\\b(namespace|package)\\s+([a-zA-Z][a-zA-Z0-9.]*)",
          "captures": {
            "1": { "name": "keyword.other.nsharp" },
            "2": { "name": "entity.name.namespace.nsharp" }
          }
        },
        {
          "name": "meta.declaration.import.nsharp",
          "match": "\\b(import|using)\\s+([a-zA-Z][a-zA-Z0-9.]*)",
          "captures": {
            "1": { "name": "keyword.other.nsharp" },
            "2": { "name": "entity.name.namespace.nsharp" }
          }
        },
        {
          "name": "meta.declaration.class.nsharp",
          "match": "\\b(class|struct|record|interface|enum|union)\\s+([A-Z][a-zA-Z0-9]*)",
          "captures": {
            "1": { "name": "keyword.other.nsharp" },
            "2": { "name": "entity.name.type.class.nsharp" }
          }
        },
        {
          "name": "meta.declaration.function.nsharp",
          "match": "\\b(func)\\s+([a-zA-Z][a-zA-Z0-9]*)\\s*(<[^>]+>)?\\s*(?=\\()",
          "captures": {
            "1": { "name": "keyword.other.nsharp" },
            "2": { "name": "entity.name.function.nsharp" }
          }
        },
        {
          "name": "meta.declaration.type-alias.nsharp",
          "match": "\\b(type)\\s+([A-Z][a-zA-Z0-9]*)\\s*(=)",
          "captures": {
            "1": { "name": "storage.type.nsharp" },
            "2": { "name": "entity.name.type.nsharp" },
            "3": { "name": "keyword.operator.assignment.nsharp" }
          }
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.property.nsharp",
          "match": "\\b[A-Z][a-zA-Z0-9]*(?=\\s*:(?!=))"
        },
        {
          "name": "variable.other.nsharp",
          "match": "\\b[a-z][a-zA-Z0-9]*(?=\\s*:(?!=))"
        }
      ]
    }
  }
}
